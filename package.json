{
  "name": "token-usage-ledger",
  "version": "0.1.23",
  "description": "Durable SQLite token usage ledger and report command for OpenClaw.",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src/**",
    "openclaw.plugin.json",
    "README.md"
  ],
  "bin": {
    "openclaw-token-usage-report": "src/report.js"
  },
  "openclaw": {
    "extensions": [
      "./src/index.js"
    ],
    "compat": {
      "pluginApi": "2026.6.1"
    },
    "install": {
      "minHostVersion": ">=2026.6.1"
    }
  },
  "scripts": {
    "test": "node --test",
    "report": "node src/report.js",
    "release:pack": "node scripts/release-pack.mjs",
    "release:patch": "node scripts/release-pack.mjs --bump patch",
    "release:minor": "node scripts/release-pack.mjs --bump minor",
    "release:major": "node scripts/release-pack.mjs --bump major"
  },
  "dependencies": {
    "sql.js": "^1.13.0"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
